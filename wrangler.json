{
  "name": "api-gateway",
  "main": "src/main.py",
  "compatibility_date": "2024-12-18",
  "compatibility_flags": ["python_workers"],
  "port": 8788,
  "triggers": {
    "crons": ["*/30 * * * *"]
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}